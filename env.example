# ── OpenAI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...


# ── LangSmith Observability ──────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ipl-ai-platform

# ── PostgreSQL (Supabase) ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# ── Qdrant ───────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                     # leave blank for local docker

# ── Redis ────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Live Cricket API ─────────────────────────────────────────────────────────────
CRICAPI_KEY=                        # CricAPI – USD 5.99/mo (production)
RAPIDAPI_KEY=                       # RapidAPI Cricbuzz – free (development)

# ── Kaggle ───────────────────────────────────────────────────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── App settings ─────────────────────────────────────────────────────────────────
ENV=development                     # development | production
LOG_LEVEL=INFO
CACHE_TTL_SECONDS=3600
REDIS_CACHE_MAX_POPULAR=50
INTENT_MODEL_PATH=ml/models/intent_classifier.joblib
WIN_PROB_MODEL_PATH=ml/models/win_probability.joblib

# ── Foundry IQ (Azure AI Search) ─────────────────────────────────────────────
# Required to enable Foundry IQ agentic retrieval.
# Create an Azure AI Search resource at https://portal.azure.com
# then set the endpoint and admin key below.
AZURE_SEARCH_ENDPOINT=https://<your-search-resource>.search.windows.net
AZURE_SEARCH_API_KEY=<your-azure-search-admin-key>
AZURE_SEARCH_INDEX_NAME=ipl-knowledge
FOUNDRY_IQ_ENABLED=true
